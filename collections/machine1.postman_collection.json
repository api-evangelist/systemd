  "info": {
    "_postman_id": "44f28ab2-15af-4847-a7b2-27cf61d7b229",
    "name": "systemd-machined (org.freedesktop.machine1)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Documentation/contract artifact for the `org.freedesktop.machine1` D-Bus interface set on the\nsystem bus, exposed by systemd-machined. Tracks local containers and virtual machines\nregistered with the system, lists/inspects/imports machine images, opens shells inside\ncontainers, and copies files in/out across container boundaries.\n",
      "type": "text/plain"
    }
  }
