    "_postman_id": "a1fc28b7-6dfc-448e-9dcd-769dfcb6e9f9",
    "name": "systemd-logind (org.freedesktop.login1)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Documentation/contract artifact modeling the `org.freedesktop.login1` D-Bus interface set\n(system bus). systemd-logind tracks user logins, seats, sessions, and inhibitor locks; gates\npower/reboot/sleep operations; manages ACLs for hot-pluggable devices; and exposes inhibitor\nlocks so applications can delay shutdown or idle handling.\n\nBus name: `org.freedesktop.login1`. Root object path: `/org/freedesktop/login1`.\n",
      "type": "text/plain"
    }
  }
