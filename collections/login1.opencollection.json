{
  "opencollection": "1.0.0",
  "info": {
    "name": "systemd-logind (org.freedesktop.login1)",
    "version": "1.0"
  },
  "items": [
    {
      "info": {
        "name": "Sessions",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List All Active Sessions",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "dbus://system/org.freedesktop.login1/sessions"
          },
          "docs": "Mirrors `ListSessions()`. Returns an array of (session id, uid, user name, seat id, object path)."
        },
        {
          "info": {
            "name": "Get A Session By ID",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "dbus://system/org.freedesktop.login1/sessions/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Mirrors `GetSession(id)`. Returns the session object path."
        },
        {
          "info": {
            "name": "Terminate A Session",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "dbus://system/org.freedesktop.login1/sessions/:id/terminate",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Mirrors `TerminateSession(id)`. Kills all processes in the session's cgroup."
        },
        {
          "info": {
            "name": "Request Session Lock",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "dbus://system/org.freedesktop.login1/sessions/:id/lock",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Mirrors `LockSession(id)`. Asks the session's lock UI to engage."
        },
        {
          "info": {
            "name": "Request Session Unlock",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "dbus://system/org.freedesktop.login1/sessions/:id/unlock",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Mirrors `UnlockSession(id)`."
        }
      ]
    },
    {
