          "info": {
            "name": "Set DNS Servers On A Link",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "dbus://system/org.freedesktop.resolve1/links/:ifindex/dns",
            "params": [
              {
                "name": "ifindex",
                "value": "",
