  "info": {
    "_postman_id": "f082a7b0-5e1f-4ac0-8287-103c306d33c7",
    "name": "systemd-networkd (org.freedesktop.network1)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Documentation/contract artifact for the `org.freedesktop.network1` D-Bus interface set on the\nsystem bus, exposed by systemd-networkd. Provides per-link state introspection plus methods to\nreconfigure, force-renew DHCP, set DNS/NTP/domains, and reload configuration.\n\nBus name: `org.freedesktop.network1`. Root: `/org/freedesktop/network1`.\n",
      "type": "text/plain"
    }
  }
